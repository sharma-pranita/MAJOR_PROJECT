{
  "name": "cloudshield-fullstack",
  "version": "1.0.0",
  "description": "CloudShield Fullstack App",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "backend": "npm --prefix backend run dev",
    "frontend": "set NODE_NO_WARNINGS=1 && npm --prefix frontend start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
